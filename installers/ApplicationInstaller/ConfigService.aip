  <COMPONENT cid="caphyon.advinst.msicomp.MsiControlConditionComponent">
    <ROW Dialog_="MyCustomizeDlg" Control_="Browse" Action="Hide" Condition="Installed"/>
    <ROW Dialog_="MyCustomizeDlg" Control_="LocationLabel" Action="Hide" Condition="Installed"/>
    <ROW Dialog_="MyCustomizeDlg" Control_="Location" Action="Hide" Condition="Installed"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="Next" Action="Disable" Condition="AI_USER_VALID_PASSWORD = &quot;No&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="Next" Action="Enable" Condition="AI_USER_VALID_PASSWORD = &quot;Yes&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="Validate" Action="Disable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;Yes&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="Validate" Action="Enable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="PasswordEdit" Action="Disable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;Yes&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="PasswordEdit" Action="Enable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="UserEdit" Action="Disable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;Yes&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="UserEdit" Action="Enable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="DomainEdit" Action="Disable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;Yes&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="DomainEdit" Action="Enable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="Next" Action="Enable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;Yes&quot;"/>
    <ROW Dialog_="ProjectionUserDlg" Control_="Next" Action="Disable" Condition="PROJECTIONUSELOCALSYSTEMACCOUNT = &quot;&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_1" Action="Enable" Condition="ADDSERVICEHTTPBINDING = &quot;Yes&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_1" Action="Disable" Condition="ADDSERVICEHTTPBINDING = &quot;&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_2" Action="Enable" Condition="ADDSERVICEHTTPBINDING = &quot;Yes&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_2" Action="Disable" Condition="ADDSERVICEHTTPBINDING = &quot;&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_3" Action="Enable" Condition="ADDSERVICEHTTPBINDING = &quot;Yes&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_3" Action="Disable" Condition="ADDSERVICEHTTPBINDING = &quot;&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_4" Action="Enable" Condition="ADDSERVICEHTTPSBINDING = &quot;Yes&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_4" Action="Disable" Condition="ADDSERVICEHTTPSBINDING = &quot;&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_5" Action="Disable" Condition="ADDSERVICEHTTPSBINDING = &quot;&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_5" Action="Enable" Condition="ADDSERVICEHTTPSBINDING = &quot;Yes&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_6" Action="Enable" Condition="ADDSERVICEHTTPSBINDING = &quot;Yes&quot;"/>
    <ROW Dialog_="ServiceBindingDlg" Control_="Edit_6" Action="Disable" Condition="ADDSERVICEHTTPSBINDING = &quot;&quot;"/>
    <ROW Dialog_="CertSelectionDlg" Control_="Next" Action="Disable" Condition="SERVICECERTIFICATETHUMBPRINT = &quot;0000000000000000000000000000000000000000&quot;"/>
    <ROW Dialog_="CertSelectionDlg" Control_="Next" Action="Enable" Condition="NOT (SERVICECERTIFICATETHUMBPRINT = &quot;0000000000000000000000000000000000000000&quot;)"/>
